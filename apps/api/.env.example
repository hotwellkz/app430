# Порт HTTP API
PORT=3001

# CORS: через запятую (sip-editor dev + crm dev)
CORS_ORIGINS=http://localhost:5174,http://localhost:5173

# Режим для health/details и логирования
NODE_ENV=development

# Клиенты обязаны слать x-sip-user-id (Firebase UID). См. docs/technical-decisions.md

# Firebase Admin (один из вариантов):
# 1) Путь к JSON service account
GOOGLE_APPLICATION_CREDENTIALS=

# 2) Или вся JSON-строка (как в Netlify), без переносов или с \n
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Предпочтительно для Cloud Run: указать project id явно
# FIREBASE_PROJECT_ID=

# GCS bucket для import-sources / export (любое имя в проекте). Если default Firebase Storage не включён —
# создайте бакет: gcloud storage buckets create gs://PROJECT-sip-imports --location=europe-west3
# FIREBASE_STORAGE_BUCKET=

# Для Cloud Run можно НЕ задавать FIREBASE_SERVICE_ACCOUNT_JSON:
# используйте attached service account + IAM роли к Firestore.
