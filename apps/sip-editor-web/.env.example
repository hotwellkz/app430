# Базовый URL API.
# Локально: оставьте пустым — запросы на /api, Vite проксирует на :3001 (vite.config.ts).
# Альтернатива (как в CRM/Netlify): VITE_API_BASE_URL=/sip-editor-api — тот же прокси в vite.config.ts.
# Netlify (один сайт с redirect /sip-editor-api): VITE_API_BASE_URL=/sip-editor-api — без CORS.
# Не используйте абсолютный *.run.app в превью Netlify без CORS на API или без этого proxy.
# VITE_API_BASE_URL=

# Origin CRM для кнопок guard-экрана «Перейти к SIP Проектам» (если CRM на другом порту, например :5173)
# VITE_CRM_ORIGIN=http://localhost:5173

# Примечание: значение должно быть абсолютным URL или относительным префиксом "/..."

# Таймауты SIP API (мс). По умолчанию JSON 120 с, загрузка файлов 10 мин.
# VITE_SIP_API_TIMEOUT_MS=180000
# VITE_SIP_API_UPLOAD_TIMEOUT_MS=1200000
