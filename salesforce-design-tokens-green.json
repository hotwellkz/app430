{
  "meta": {
    "pageType": "landing",
    "originalSite": "Salesforce CRM (salesforce.com)",
    "layout": "multi-column",
    "theme": "light",
    "style": "corporate-friendly",
    "colorSchemeOverride": "light-green (adapted from original Salesforce blue)"
  },

  "tokens": {
    "colors": {
      "primary": "#2D8653",
      "primaryHover": "#236B42",
      "primaryLight": "#E6F4EC",
      "secondary": "#1A5C38",
      "accent": "#4CAF78",
      "accentLight": "#A8D9BC",
      "background": "#FFFFFF",
      "backgroundPage": "#F4FAF7",
      "backgroundSection": "#EDF7F2",
      "backgroundGradient": "linear-gradient(135deg, #EDF7F2 0%, #D6EEE3 100%)",
      "surface": "#FFFFFF",
      "surfaceElevated": "#F0F9F5",
      "text": {
        "primary": "#0D2B1E",
        "secondary": "#1E5C3A",
        "muted": "#5A8A72",
        "inverse": "#FFFFFF",
        "link": "#2D8653",
        "linkHover": "#1A5C38",
        "accent": "#4CAF78"
      },
      "border": "#B8DEC9",
      "borderLight": "#D9EFE4",
      "borderFocus": "#2D8653",
      "cardBorder": "#C8E6D4",
      "cardTopAccent": {
        "green": "#4CAF78",
        "teal": "#2DBFA0",
        "mint": "#52C9A8",
        "sage": "#7BC49A",
        "lime": "#95D44A"
      },
      "error": "#D93025",
      "success": "#2D8653",
      "warning": "#F29900",
      "info": "#1A73E8",
      "checkmark": "#2D8653",
      "chatBubble": "#2D8653",
      "chatBubbleHover": "#236B42"
    },

    "typography": {
      "fontFamilies": {
        "heading": "Salesforce Sans, Arial, sans-serif",
        "body": "Salesforce Sans, Arial, sans-serif",
        "mono": null,
        "note": "Salesforce uses their proprietary 'Salesforce Sans'. Fallback: 'Source Sans Pro' or 'Open Sans' from Google Fonts"
      },
      "fontSizes": {
        "xs": "12px",
        "sm": "14px",
        "base": "16px",
        "lg": "18px",
        "xl": "20px",
        "2xl": "24px",
        "3xl": "28px",
        "4xl": "32px",
        "5xl": "40px",
        "6xl": "48px",
        "hero": "52px"
      },
      "fontWeights": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700,
        "extrabold": 800
      },
      "lineHeights": {
        "tight": "1.1",
        "snug": "1.25",
        "normal": "1.5",
        "relaxed": "1.65"
      },
      "letterSpacings": {
        "tight": "-0.01em",
        "normal": "0em",
        "wide": "0.03em",
        "wider": "0.08em"
      }
    },

    "spacing": {
      "unit": "8px",
      "scale": ["4px", "8px", "12px", "16px", "20px", "24px", "32px", "40px", "48px", "64px", "80px", "96px", "128px"]
    },

    "borderRadius": {
      "none": "0px",
      "xs": "2px",
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "20px",
      "3xl": "24px",
      "full": "9999px",
      "card": "12px",
      "button": "6px",
      "badge": "4px",
      "pill": "9999px"
    },

    "shadows": {
      "sm": "0 1px 4px rgba(0,0,0,0.08)",
      "md": "0 2px 8px rgba(0,0,0,0.1)",
      "lg": "0 4px 16px rgba(0,0,0,0.12)",
      "xl": "0 8px 32px rgba(0,0,0,0.14)",
      "card": "0 2px 12px rgba(45, 134, 83, 0.1)",
      "cardHover": "0 6px 24px rgba(45, 134, 83, 0.18)"
    },

    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    },

    "transitions": {
      "fast": "all 0.15s ease",
      "base": "all 0.2s ease",
      "slow": "all 0.3s ease"
    }
  },

  "layout": {
    "maxWidth": "1440px",
    "contentMaxWidth": "1200px",
    "containerPadding": "24px",
    "sectionPaddingY": "80px",
    "grid": {
      "columns": 12,
      "gap": "24px",
      "columnGap": "24px",
      "rowGap": "32px"
    },
    "sections": [
      {
        "id": "top-utility-bar",
        "type": "utility-bar",
        "backgroundColor": "#FFFFFF",
        "height": "48px",
        "padding": { "top": "0px", "bottom": "0px", "left": "24px", "right": "24px" },
        "layout": "flex space-between — contact info left, search center-right, CTA right",
        "borderBottom": "1px solid #B8DEC9"
      },
      {
        "id": "sub-navbar",
        "type": "secondary-navbar",
        "backgroundColor": "#FFFFFF",
        "height": "56px",
        "padding": { "top": "0px", "bottom": "0px", "left": "24px", "right": "24px" },
        "layout": "CRM logo left, nav links center, CTA buttons right",
        "borderBottom": "1px solid #D9EFE4"
      },
      {
        "id": "hero",
        "type": "hero",
        "backgroundColor": "#FFFFFF",
        "backgroundType": "solid with illustrated landscape on right edge",
        "padding": { "top": "60px", "bottom": "60px", "left": "120px", "right": "60px" },
        "layout": "left-aligned text (col 5), right media with video thumbnail (col 7)"
      },
      {
        "id": "ai-chat-section",
        "type": "cta-chat",
        "backgroundColor": "#EDF7F2",
        "padding": { "top": "40px", "bottom": "40px", "left": "auto", "right": "auto" },
        "maxWidth": "720px",
        "layout": "centered — heading above, AI chat input below with quick action buttons"
      },
      {
        "id": "cards-3col",
        "type": "features",
        "backgroundColor": "#F4FAF7",
        "padding": { "top": "64px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "centered heading, 3-column card grid below, illustrated landscape background"
      },
      {
        "id": "split-content-1",
        "type": "feature-split",
        "backgroundColor": "#FFFFFF",
        "padding": { "top": "80px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "left text col-5 (heading + body + CTA), right illustration col-7"
      },
      {
        "id": "split-content-2",
        "type": "feature-split",
        "backgroundColor": "#FFFFFF",
        "padding": { "top": "80px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "left illustration col-7 (circular framed photo + decorative dots), right text col-5"
      },
      {
        "id": "industry-split",
        "type": "feature-split",
        "backgroundColor": "#FFFFFF",
        "padding": { "top": "80px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "left text col-5, right collage of circular avatars + mascot illustration"
      },
      {
        "id": "product-cards-grid",
        "type": "products",
        "backgroundColor": "#F4FAF7",
        "padding": { "top": "64px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "centered heading, grid of product cards — top row 3 cols, bottom row 2 cols centered"
      },
      {
        "id": "pricing-cards",
        "type": "pricing",
        "backgroundColor": "linear-gradient(180deg, #EDF7F2 0%, #D4EDDF 100%)",
        "padding": { "top": "64px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "left side label text, right side 2 white cards side by side + single CTA button below"
      },
      {
        "id": "customer-logos",
        "type": "social-proof",
        "backgroundColor": "#FFFFFF",
        "padding": { "top": "64px", "bottom": "64px", "left": "80px", "right": "80px" },
        "layout": "centered heading + CTA button, then 5 client logo tiles in a row"
      },
      {
        "id": "resource-cards-3col",
        "type": "resources",
        "backgroundColor": "#F4FAF7",
        "padding": { "top": "64px", "bottom": "80px", "left": "80px", "right": "80px" },
        "layout": "left side-label text, right 3 content cards with image thumbnails + badges + links"
      },
      {
        "id": "signup-form-page",
        "type": "registration",
        "backgroundColor": "#EDF7F2",
        "padding": { "top": "0px", "bottom": "0px", "left": "0px", "right": "0px" },
        "layout": "left half: logo + benefits list + product illustration; right half: form card on white"
      },
      {
        "id": "signup-modal-step",
        "type": "modal-form",
        "backgroundColor": "#EDF7F2",
        "padding": { "top": "0px", "bottom": "0px", "left": "0px", "right": "0px" },
        "layout": "centered modal card on light green bg — logo top, heading, form fields, submit button"
      },
      {
        "id": "chat-widget-fullscreen",
        "type": "chat",
        "backgroundColor": "linear-gradient(135deg, #F0F9F5 0%, #E6F4EC 100%)",
        "padding": { "top": "32px", "bottom": "32px", "left": "32px", "right": "32px" },
        "layout": "top-left: Agentforce label. Centered: heading. Chat messages below. Input fixed at bottom."
      }
    ]
  },

